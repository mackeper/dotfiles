{
    "func": {
        "prefix": "func",
        "body": [
            "function ${1:name}(${2:args})",
            "\t$0",
            "end"
        ],
        "description": "Create a Lua function"
    },
    "local func": {
        "prefix": "lfunc",
        "body": [
            "local function ${1:name}(${2:args})",
            "\t$0",
            "end"
        ],
        "description": "Create a local Lua function"
    },
    "for": {
        "prefix": "for",
        "body": [
            "for ${1:i} = ${2:1}, ${3:10} do",
            "\t$0",
            "end"
        ],
        "description": "Create a for loop"
    },
    "forin": {
        "prefix": "forin",
        "body": [
            "for ${1:k}, ${2:v} in pairs(${3:tbl}) do",
            "\t$0",
            "end"
        ],
        "description": "Create a for-in loop (pairs)"
    },
    "if": {
        "prefix": "if",
        "body": [
            "if ${1:condition} then",
            "\t$0",
            "end"
        ],
        "description": "Create an if statement"
    },
    "ifelse": {
        "prefix": "ifelse",
        "body": [
            "if ${1:condition} then",
            "\t$0",
            "else",
            "\t",
            "end"
        ],
        "description": "Create an if-else statement"
    }
}
