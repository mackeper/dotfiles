PKI_DIR=$HOME/tls/pki
WEB_HOST=nginx
WEB_PATH=/var/www/pki
DOMAIN=http://pki.realmoneycompany.com

SERVER_NAME=gcp
ENCRYPTION_SIZE=4096

OPENVPN_DIR=$HOME/tls/openvpn
OPENVPN_SERVER_URL=normalcat.ddns.net

CA_NAME="RealMoneyCompany Root CA"
CA_CERT_NAME="realmoneycompany_root_ca"
INTERMEDIATE_NAME="RealMoneyCompany Intermediate CA"
INTERMEDIATE_CERT_NAME="realmoneycompany_intermediate_ca"
CHAIN_CERT_NAME="realmoneycompany_chain_ca"

KEY_FILE_EXTENSION=".key"
CA_FILE_EXTENSION=".crt"
CRL_FILE_EXTENSION=".crl"
CSR_FILE_EXTENSION=".csr"
CERT_FILE_EXTENSION=".crt"
CHAIN_FILE_EXTENSION=".pem"

CA_KEY_PATH="private/$CA_CERT_NAME$KEY_FILE_EXTENSION"
CA_CERT_PATH="ca/$CA_CERT_NAME$CA_FILE_EXTENSION"
CA_CRL_PATH="crl/$CA_CERT_NAME$CRL_FILE_EXTENSION"

INTERMEDIATE_KEY_PATH="private/$INTERMEDIATE_CERT_NAME$KEY_FILE_EXTENSION"
INTERMEDIATE_CERT_PATH="ca/$INTERMEDIATE_CERT_NAME$CA_FILE_EXTENSION"
INTERMEDIATE_CSR_PATH="csr/$INTERMEDIATE_CERT_NAME$CSR_FILE_EXTENSION"
INTERMEDIATE_CRL_PATH="crl/$INTERMEDIATE_CERT_NAME$CRL_FILE_EXTENSION"

CHAIN_CERT_PATH="ca/$CHAIN_CERT_NAME$CHAIN_FILE_EXTENSION"
